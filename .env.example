# --- Integra SaaS Configuration Template ---
# Copy this file to .env and fill in your actual keys.

# 1. Supabase (Database & Auth)
# Get these from: Project Settings -> API
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_private_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# 2. Stripe (Payments)
# Get these from: Developers -> API Keys
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# 3. LiveKit (Video & Audio)
# Get these from: LiveKit Cloud Dashboard
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here

# 4. System & Mail
# Use an App Password for Gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# 5. Environment
FRONTEND_URL=http://localhost:5500
BACKEND_URL=http://localhost:8000

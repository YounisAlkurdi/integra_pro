{
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/pages/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/js/**/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/css/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/main.py"
    },
    {
      "src": "/config",
      "dest": "backend/main.py"
    },
    {
      "src": "/create-payment-intent",
      "dest": "backend/main.py"
    },
    {
      "src": "/js/(.*)",
      "dest": "/frontend/js/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/frontend/css/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/(dashboard|login|pricing|checkout|reports|appointments|billing|llm-config|integra-session|profile)",
      "dest": "/frontend/pages/$1.html"
    },
    {
      "src": "/index.html",
      "dest": "/frontend/pages/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/pages/$1",
      "continue": true
    },
    {
      "src": "/",
      "dest": "/frontend/pages/index.html"
    }
  ]
}


{
  "version": 2,
  "builds": [
    { "src": "frontend/**", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "data/**", "use": "@vercel/static" },
    { "src": "robots.txt", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/data/(.*)", "dest": "/data/$1" },
    { "src": "/css/(.*)", "dest": "/frontend/css/$1" },
    { "src": "/js/(.*)", "dest": "/frontend/js/$1" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/", "dest": "/frontend/pages/index.html" },
    { "src": "/index", "dest": "/frontend/pages/index.html" },
    { "src": "/login", "dest": "/frontend/pages/login.html" },
    { "src": "/dashboard", "dest": "/frontend/pages/dashboard.html" },
    { "src": "/appointments", "dest": "/frontend/pages/appointments.html" },
    { "src": "/billing", "dest": "/frontend/pages/billing.html" },
    { "src": "/checkout", "dest": "/frontend/pages/checkout.html" },
    { "src": "/integra-session", "dest": "/frontend/pages/integra-session.html" },
    { "src": "/llm-config", "dest": "/frontend/pages/llm-config.html" },
    { "src": "/pricing", "dest": "/frontend/pages/pricing.html" },
    { "src": "/profile", "dest": "/frontend/pages/profile.html" },
    { "src": "/reports", "dest": "/frontend/pages/reports.html" }
  ]
}

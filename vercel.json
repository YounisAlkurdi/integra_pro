{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/assets/:match*",
      "destination": "/assets/:match*"
    },
    {
      "source": "/data/:match*",
      "destination": "/data/:match*"
    },
    {
      "source": "/css/:match*",
      "destination": "/frontend/css/:match*"
    },
    {
      "source": "/js/:match*",
      "destination": "/frontend/js/:match*"
    },
    {
      "source": "/",
      "destination": "/frontend/pages/index.html"
    },
    {
      "source": "/:path",
      "destination": "/frontend/pages/:path.html"
    }
  ]
}

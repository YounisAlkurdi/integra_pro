{
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "data/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/.well-known/(.*)",
      "dest": "/.well-known/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "backend/main.py"
    },

    {
      "src": "/create-payment-intent",
      "dest": "backend/main.py"
    },
    {
      "src": "/config",
      "dest": "backend/main.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/data/(.*)",
      "dest": "/data/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/frontend/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/frontend/js/$1"
    },
    {
      "src": "/pages/(.*)",
      "dest": "/frontend/pages/$1"
    },
    {
      "src": "/",
      "dest": "/frontend/pages/index.html"
    },
    {
      "src": "/index\\.html",
      "dest": "/frontend/pages/index.html"
    },
    {
      "src": "/login\\.html",
      "dest": "/frontend/pages/login.html"
    },
    {
      "src": "/dashboard\\.html",
      "dest": "/frontend/pages/dashboard.html"
    },
    {
      "src": "/appointments\\.html",
      "dest": "/frontend/pages/appointments.html"
    },
    {
      "src": "/billing\\.html",
      "dest": "/frontend/pages/billing.html"
    },
    {
      "src": "/checkout\\.html",
      "dest": "/frontend/pages/checkout.html"
    },
    {
      "src": "/integra-session\\.html",
      "dest": "/frontend/pages/integra-session.html"
    },
    {
      "src": "/llm-config\\.html",
      "dest": "/frontend/pages/llm-config.html"
    },
    {
      "src": "/pricing\\.html",
      "dest": "/frontend/pages/pricing.html"
    },
    {
      "src": "/profile\\.html",
      "dest": "/frontend/pages/profile.html"
    },
    {
      "src": "/reports\\.html",
      "dest": "/frontend/pages/reports.html"
    },
    {
      "src": "/(.*\\.html)",
      "dest": "/frontend/pages/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/pages/$1"
    }
  ]
}
